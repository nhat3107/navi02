# Copy to .env for local Docker:  cp .env.docker.example .env
# User app: http://localhost:8080  |  Admin: http://localhost:8081  |  API: http://localhost:3000/api

# --- Required ---
JWT_ACCESS_SECRET=change-me-access
JWT_RESET_SECRET=change-me-reset

# --- Postgres (in-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
AUTH_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auth_db
USER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/user_db

# --- Mongo (in-compose) ---
MONGO_USER=root
MONGO_PASSWORD=example
CHAT_DATABASE_URL=mongodb://root:example@mongo:27017/chat_db?authSource=admin
NETWORK_DATABASE_URL=mongodb://root:example@mongo:27017/network_db?authSource=admin
NOTIFICATION_DATABASE_URL=mongodb://root:example@mongo:27017/notification_db?authSource=admin

# --- API gateway / CORS (comma-separated frontend origins) ---
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:8081
FRONTEND_URL=http://localhost:8080
OAUTH_FRONTEND_LOGIN_URL=http://localhost:8080/login
OAUTH_FRONTEND_REDIRECT_URL=http://localhost:8080

# OAuth callbacks: no /api prefix (routes are /auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GH_CLIENT_ID=
GH_CLIENT_SECRET=
GH_CALLBACK_URL=http://localhost:3000/auth/github/callback

# --- Frontend build args (docker compose user-app / admin-app) ---
VITE_API_URL=http://localhost:3000/api
VITE_WS_ORIGIN=http://localhost:3000
VITE_ENABLE_OAUTH=false

# --- Optional integrations ---
EMAIL_USER=
EMAIL_PASS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET=
OPENAI_API_KEY=
